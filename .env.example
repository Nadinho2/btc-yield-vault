# Copy to .env.local for development. On Vercel: Project → Settings → Environment Variables.

# Required — Privy dashboard App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional — Cartridge paymaster RPC for sponsored (gasless) txs on Sepolia
NEXT_PUBLIC_CARTRIDGE_PAYMASTER_NODE_URL=

# Optional — Starknet Sepolia JSON-RPC used by the server proxy (recommended on Vercel). Client calls /api/starknet-rpc to avoid CORS.
# The proxy races several public nodes; set this to your own Sepolia URL (Alchemy, Blast+key, etc.) for reliability and rate limits.
STARKNET_RPC_URL=

# Optional — Same as above but exposed to the browser; used as first upstream in the proxy and for direct mode.
NEXT_PUBLIC_STARKNET_RPC_URL=

# Optional — Set "true" to skip the proxy and call NEXT_PUBLIC_STARKNET_RPC_URL from the browser (may hit CORS).
NEXT_PUBLIC_STARKNET_RPC_DIRECT=

# Optional — WalletConnect Cloud project id (improves WalletConnect in Privy)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
